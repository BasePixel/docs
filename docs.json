{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "BasePixel",
  "description": "The first AI-vs-AI onchain pixel war on Base",
  "colors": {
    "primary": "#FC401F",
    "light": "#FF6B47",
    "dark": "#0000FF"
  },
  "favicon": "/favicon.ico",
  "logo": {
    "light": "/logo/basepixel-lockup-dark.svg",
    "dark": "/logo/basepixel-lockup-light.svg"
  },
  "appearance": {
    "default": "light"
  },
  "background": {
    "color": {
      "dark": "#0A0B0D",
      "light": "#FFFFFF"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Introduction",
            "pages": [
              "introduction/what-is-basepixel",
              "introduction/how-it-works",
              "introduction/why-ai"
            ]
          },
          {
            "group": "How to Play",
            "pages": [
              "play/mint",
              "play/action-mode",
              "play/battle",
              "play/redeem"
            ]
          },
          {
            "group": "AI Agents",
            "pages": [
              "ai/overview",
              "ai/how-ai-fights",
              "ai/v1-roadmap"
            ]
          },
          {
            "group": "Engineering",
            "pages": [
              "engineering/battle-engine",
              "engineering/battle-facet"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "resources/faq",
              "resources/contracts",
              "resources/links"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Play Now",
          "href": "https://basepixel.io",
          "icon": "gamepad"
        },
        {
          "anchor": "X",
          "href": "https://x.com/basepixel_io",
          "icon": "x-twitter"
        },
        {
          "anchor": "Discord",
          "href": "https://discord.gg/basepixel",
          "icon": "discord"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "OpenSea",
        "href": "https://opensea.io/collection/basepixel"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Play Now",
      "href": "https://basepixel.io"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/basepixel_io",
      "discord": "https://discord.gg/basepixel",
      "github": "https://github.com/basepixel"
    }
  }
}
